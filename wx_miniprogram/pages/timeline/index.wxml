<!--pages/timeline/index.wxml-->
<view class="container page-anim-{{ animKey }}">
  
  <!-- 1. 搜索栏 -->
  <view class="search-bar">
    <icon type="search" size="16" class="search-icon" />
    <input type="text" placeholder="搜索大事记、用药、康复、大运动..." value="{{ searchKeyword }}" bindinput="onSearchInput" />
  </view>

  <!-- 2. 分类标签滚动条 + 管理分类按钮 -->
  <view class="cat-bar-row">
    <scroll-view class="cat-scroll" scroll-x="true">
      <block wx:for="{{ categories }}" wx:key="*this">
        <view class="cat-pill {{ activeCategory === item ? 'active' : '' }}" bindtap="selectCategory" data-cat="{{ item }}">
          {{ item }}
        </view>
      </block>
    </scroll-view>
    <view class="cat-manage-btn" bindtap="openCatModal">⚙️</view>
  </view>

  <!-- 3. 时间线瀑布流列表 -->
  <view class="timeline-wrapper" wx:if="{{ filteredEvents.length > 0 }}">
    <!-- 垂直连接线 -->
    <view class="timeline-line"></view>
    
    <block wx:for="{{ filteredEvents }}" wx:key="id">
      <view class="timeline-node-item">
        <!-- 侧边小圆圈 -->
        <view class="node-bullet {{ item.category === '大运动/发育' ? 'bullet-green' : (item.category === '辅食/便秘' ? 'bullet-orange' : (item.category === '评估/康复' ? 'bullet-purple' : (item.category === '疾病用药' ? 'bullet-red' : 'bullet-blue'))) }}"></view>
        
        <!-- 大卡片 -->
        <view class="node-card card">
          <view class="node-header">
            <text class="node-date">{{ item.date }}</text>
            <text class="node-cat-lbl">{{ item.category }}</text>
            <text class="delete-btn" bindtap="deleteEvent" data-id="{{ item.id }}">✕</text>
          </view>
          <view class="node-body">
            <text class="node-title">{{ item.title }}</text>
            <text class="node-desc">{{ item.content }}</text>
          </view>
        </view>
      </view>
    </block>
  </view>
  <view class="empty-placeholder" wx:else>未匹配到相关大事记 🍃</view>

</view>

<!-- 悬浮按钮和弹窗必须在 .page-transition 容器外，否则 will-change:transform 会使 position:fixed 相对容器定位 -->

<!-- 4. 悬浮增加按钮 -->
<view class="floating-btn" bindtap="openAddModal">＋</view>

<!-- 5. 录入遮罩层弹窗 -->
<view class="modal-overlay" wx:if="{{ showModal }}">
  <view class="modal-card">
    <view class="modal-header">
      <text class="modal-title">记录小宝贝重要大时刻</text>
      <text class="modal-close" bindtap="closeAddModal">✕</text>
    </view>
    
    <view class="modal-body">
      <view class="form-item">
        <text class="lbl">日期</text>
        <picker mode="date" value="{{ evtDate }}" bindchange="onEvtInput" data-field="evtDate">
          <view class="date-picker-btn">{{ evtDate }}</view>
        </picker>
      </view>

      <view class="form-item">
        <text class="lbl">分类</text>
        <picker mode="selector" range="{{ addCategories }}" value="{{ evtCategoryIndex }}" bindchange="onCategoryChange">
          <view class="date-picker-btn">
            {{ evtCategory || '选择类别' }}
          </view>
        </picker>
      </view>

      <view class="form-item">
        <text class="lbl">大事记标题</text>
        <input type="text" placeholder="如 会翻身了、第一次吃米粉" value="{{ evtTitle }}" bindinput="onEvtInput" data-field="evtTitle" />
      </view>

      <view class="form-item">
        <text class="lbl">描述/备注详情</text>
        <textarea placeholder="填入发生了什么有趣的事、或者医生的结论..." value="{{ evtContent }}" bindinput="onEvtInput" data-field="evtContent" auto-height />
      </view>
    </view>

    <view class="modal-footer">
      <button class="btn btn-primary btn-block" bindtap="saveEvent">保存记录</button>
    </view>
  </view>
</view>

<!-- 6. 分类管理弹窗 -->
<view class="modal-overlay" wx:if="{{ showCatModal }}">
  <view class="modal-card">
    <view class="modal-header">
      <text class="modal-title">⚙️ 管理分类</text>
      <text class="modal-close" bindtap="closeCatModal">✕</text>
    </view>
    <view class="modal-body">
      <!-- 现有分类列表 -->
      <view class="cat-mgr-list">
        <view class="cat-mgr-item" wx:for="{{ categoryList }}" wx:key="*this">
          <text class="cat-mgr-name">{{ item }}</text>
          <text class="cat-mgr-del {{ item === '未分类' ? 'del-disabled' : '' }}"
            bindtap="deleteCategory" data-name="{{ item }}">
            {{ item === '未分类' ? '保留' : '删除' }}
          </text>
        </view>
      </view>
      <!-- 新增分类 -->
      <view class="form-item" style="margin-top: 24rpx;">
        <text class="lbl">添加新分类</text>
        <view style="display:flex; gap:16rpx; align-items:center; margin-top:12rpx;">
          <input style="flex:1; background:#f7f9fc; border:1rpx solid #edf2f7; border-radius:12rpx; padding:0 20rpx; height:72rpx; font-size:26rpx;"
            type="text" placeholder="输入分类名称..." value="{{ newCatName }}" bindinput="onNewCatInput" />
          <button style="background:#6CA847; color:#fff; font-size:24rpx; border-radius:12rpx; padding:0 28rpx; height:72rpx; line-height:72rpx; border:none;"
            bindtap="addCategory">添加</button>
        </view>
      </view>
    </view>
  </view>
</view>
