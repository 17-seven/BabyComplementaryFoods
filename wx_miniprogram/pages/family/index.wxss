/* pages/family/index.wxss */

/* 全局容器背景及呼吸渐变氛围 */
.container {
  min-height: 100vh;
  padding: 30rpx 24rpx;
  background: linear-gradient(180deg, #f7faf5 0%, #f1f6ee 100%);
  box-sizing: border-box;
}

/* 顶部提示 Banner */
.tip-banner {
  background: linear-gradient(135deg, #ebf8f2 0%, #def5e9 100%);
  border: 1rpx solid #c6ebd7;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 30rpx;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(108, 168, 71, 0.03);
}
.tip-icon {
  font-size: 36rpx;
  line-height: 1;
}
.tip-text {
  color: #276749;
  font-size: 24rpx;
  line-height: 1.6;
  font-weight: 500;
  flex: 1;
}

/* 通用高级卡片设计 */
.card {
  background-color: #ffffff;
  border-radius: 28rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(108, 168, 71, 0.04);
  border: 1rpx solid rgba(108, 168, 71, 0.06);
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}

/* 活跃家庭共享卡片专属 */
.family-active-card {
  border-top: 6rpx solid #6ca847;
}

/* 状态小徽章 */
.card-header-badge {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  background-color: #e6f7ff;
  border: 1rpx solid #bae7ff;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}
.badge-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #1890ff;
  animation: pulse 1.8s infinite;
}
.badge-text {
  font-size: 20rpx;
  color: #0050b3;
  font-weight: 700;
}

/* 宝宝信息展示 */
.baby-profile-section {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 36rpx;
}
.baby-avatar-badge {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  background-color: #fffbe6;
  border: 4rpx solid #ffe58f;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 229, 143, 0.2);
}
.baby-info-meta {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.baby-info-lbl {
  font-size: 20rpx;
  color: #a0aec0;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}
.baby-info-val {
  font-size: 36rpx;
  font-weight: 800;
  color: #2d3748;
}

/* 同步邀请码面板 */
.invite-display-box {
  background-color: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 20rpx;
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  transition: all 0.2s ease;
}
.invite-display-box:active {
  background-color: #f1f5f9;
}
.code-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.code-lbl {
  font-size: 20rpx;
  color: #718096;
  font-weight: 700;
}
.code-actions {
  display: flex;
  gap: 12rpx;
}
.btn-action-capsule {
  font-size: 20rpx;
  font-weight: 700;
  color: #6ca847;
  background-color: #f0fff4;
  border: 1rpx solid #c6f6d5;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  transition: all 0.15s ease;
}
.btn-action-capsule:active {
  transform: scale(0.92);
  background-color: #e6fffa;
}
.btn-qr-capsule {
  color: #4a5568;
  background-color: #f1f5f9;
  border: 1rpx solid #e2e8f0;
}
.code-val {
  font-size: 32rpx;
  font-weight: 800;
  color: #1a202c;
  font-family: Menlo, Monaco, Consolas, "Fira Code", monospace;
  letter-spacing: 1.5rpx;
  word-break: break-all;
  padding: 6rpx 0;
}
.hint-msg {
  font-size: 22rpx;
  color: #a0aec0;
  margin-top: 20rpx;
  line-height: 1.5;
}

/* 守护成员卡片及成员行 */
.members-card {
  padding-bottom: 20rpx;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  border-bottom: 1rpx solid #f1f5f9;
  padding-bottom: 20rpx;
}
.section-title-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.section-icon {
  font-size: 32rpx;
}
.section-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #2d3748;
}
.members-count-badge {
  font-size: 20rpx;
  font-weight: 700;
  color: #6ca847;
  background-color: #f0fff4;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.members-list-wrapper {
  display: flex;
  flex-direction: column;
}
.member-card-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx dashed #e2e8f0;
}
.member-card-row:last-child {
  border-bottom: none;
}
.member-avatar {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  border: 4rpx solid #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  background-color: #f1f5f9;
}
.member-detail-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  overflow: hidden;
}
.member-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.member-nickname {
  font-size: 26rpx;
  font-weight: 800;
  color: #2d3748;
}
.role-tag-badge {
  font-size: 16rpx;
  font-weight: 700;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}
.tag-creator {
  background-color: #fff9e6;
  color: #b78103;
  border: 1rpx solid #ffe58f;
}
.tag-helper {
  background-color: #f0fdf4;
  color: #166534;
  border: 1rpx solid #bbf7d0;
}
.member-id-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.id-lbl {
  font-size: 18rpx;
  color: #cbd5e0;
  font-weight: 700;
}
.id-val {
  font-size: 18rpx;
  color: #a0aec0;
  font-family: monospace;
  max-width: 280rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.remove-member-btn {
  font-size: 22rpx;
  color: #e53e3e;
  background-color: #fff5f5;
  border: 1rpx solid #fed7d7;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
  margin-left: 20rpx;
  font-weight: 500;
  display: inline-block;
  cursor: pointer;
  transition: all 0.2s ease;
}
.remove-member-btn:active {
  background-color: #fed7d7;
  transform: scale(0.95);
}

/* 解绑退出按钮设计 (高级轻量警示幽灵按钮) */
.danger-zone-wrapper {
  margin-top: 40rpx;
  padding: 0 10rpx;
}
.btn-danger-ghost {
  background-color: #fff5f5 !important;
  color: #c53030 !important;
  border: 2rpx solid #feb2b2 !important;
  border-radius: 20rpx !important;
  font-size: 26rpx !important;
  font-weight: 700 !important;
  padding: 24rpx 0 !important;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(254, 178, 178, 0.1);
  transition: all 0.2s ease;
  width: 100%;
  box-sizing: border-box;
}
.btn-danger-ghost:active {
  background-color: #fff0f0 !important;
  transform: scale(0.98);
}
.btn-danger-icon {
  font-size: 32rpx;
}

/* ==================== 情况B: 未绑定模块高级插画卡片 ==================== */
.design-card {
  border: 1rpx solid rgba(255,255,255,0.7);
  box-shadow: 0 10rpx 40rpx rgba(108, 168, 71, 0.05);
}
.create-card {
  border-top: 8rpx solid #6ca847;
}
.join-card {
  border-top: 8rpx solid #dd6b20;
}

/* 卡片高光光斑效果 */
.card-bg-glow {
  position: absolute;
  top: -80rpx;
  right: -80rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  filter: blur(40rpx);
  opacity: 0.15;
  pointer-events: none;
}
.glow-green {
  background-color: #6ca847;
}
.glow-orange {
  background-color: #dd6b20;
}

/* 升级卡片头部标题结构 */
.section-header-styled {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}
.card-title-icon {
  width: 70rpx;
  height: 70rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}
.bg-green {
  background-color: #f0fff4;
  color: #38a169;
}
.bg-orange {
  background-color: #fffaf0;
  color: #dd6b20;
}
.card-title-meta {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.title-main {
  font-size: 28rpx;
  font-weight: 800;
  color: #2d3748;
}
.title-sub {
  font-size: 20rpx;
  color: #a0aec0;
  font-weight: 600;
}

.card-description-text {
  font-size: 24rpx;
  color: #718096;
  line-height: 1.6;
  display: block;
  margin-bottom: 30rpx;
}

/* 渐变主按钮系统 */
.btn-gradient {
  width: 100%;
  border-radius: 20rpx !important;
  font-size: 26rpx !important;
  font-weight: 700 !important;
  padding: 24rpx 0 !important;
  color: #ffffff !important;
  border: none !important;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.05);
  transition: all 0.2s ease;
}
.btn-gradient:active {
  transform: scale(0.98);
}
.btn-gradient-green {
  background: linear-gradient(135deg, #6ca847 0%, #578c35 100%) !important;
  box-shadow: 0 6rpx 20rpx rgba(108, 168, 71, 0.25) !important;
}
.btn-gradient-emerald {
  background: linear-gradient(135deg, #059669 0%, #047857 100%) !important;
  box-shadow: 0 6rpx 20rpx rgba(5, 150, 105, 0.25) !important;
}

/* 分割线样式 */
.divider-section {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 40rpx 0;
  gap: 24rpx;
}
.divider-line {
  flex: 1;
  height: 2rpx;
  background-color: #e2e8f0;
}
.divider-text {
  font-size: 22rpx;
  color: #cbd5e0;
  font-weight: 700;
  text-transform: uppercase;
}

/* 输入与确认框横条组合 */
.input-binding-bar {
  display: flex;
  gap: 16rpx;
  align-items: center;
  margin-top: 24rpx;
}
.styled-invite-input {
  flex: 1;
  background-color: #f8fafc;
  border: 1rpx solid #cbd5e0;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 24rpx;
  color: #2d3748;
  height: 80rpx;
  box-sizing: border-box;
  transition: all 0.2s ease;
}
.styled-invite-input:focus {
  border-color: #dd6b20;
  background-color: #ffffff;
}
.btn-bind-confirm {
  background: linear-gradient(135deg, #f6ad55 0%, #dd6b20 100%) !important;
  color: #ffffff !important;
  font-size: 24rpx !important;
  font-weight: 700 !important;
  border-radius: 16rpx !important;
  padding: 0 32rpx !important;
  height: 80rpx !important;
  line-height: 80rpx !important;
  border: none !important;
  box-shadow: 0 4rpx 12rpx rgba(221, 107, 32, 0.2) !important;
  margin: 0 !important;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-bind-confirm:active {
  transform: scale(0.95);
}

/* ==================== 模态弹窗优化 ==================== */
.qr-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.65);
  backdrop-filter: blur(10rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;
  animation: fadeIn 0.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}
.qr-modal-content {
  width: 86%;
  background-color: #ffffff;
  border-radius: 32rpx;
  padding: 44rpx;
  box-sizing: border-box;
  position: relative;
  box-shadow: 0 20rpx 50rpx rgba(0, 0, 0, 0.25);
  animation: scaleUp 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  border: 1rpx solid rgba(255,255,255,0.8);
}
.qr-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  border-bottom: 2rpx solid #f1f5f9;
  padding-bottom: 24rpx;
}
.qr-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #1a202c;
}
.qr-close-icon {
  font-size: 32rpx;
  color: #a0aec0;
  padding: 6rpx 16rpx;
  border-radius: 50%;
  background-color: #f7fafc;
  line-height: 1;
}
.qr-close-icon:active {
  background-color: #e2e8f0;
}
.qr-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 28rpx;
}
.qr-img {
  width: 320rpx;
  height: 320rpx;
  padding: 16rpx;
  background-color: #ffffff;
  border: 2rpx solid #e2e8f0;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
}
.qr-hint {
  font-size: 22rpx;
  color: #718096;
  line-height: 1.6;
  text-align: center;
  background-color: #f8fafc;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid #edf2f9;
}
.qr-sync-code-box {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background-color: #fffbeb;
  border: 1rpx solid #fef3c7;
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  width: 100%;
  box-sizing: border-box;
}
.sync-code-lbl {
  font-size: 22rpx;
  color: #d97706;
  font-weight: 800;
}
.sync-code-val {
  font-size: 24rpx;
  font-weight: 800;
  color: #78350f;
  font-family: monospace;
  word-break: break-all;
}

/* 动效 */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes scaleUp {
  from { transform: scale(0.92); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}
@keyframes pulse {
  0% { box-shadow: 0 0 0 0 rgba(24, 144, 255, 0.4); }
  70% { box-shadow: 0 0 0 10rpx rgba(24, 144, 255, 0); }
  100% { box-shadow: 0 0 0 0 rgba(24, 144, 255, 0); }
}
