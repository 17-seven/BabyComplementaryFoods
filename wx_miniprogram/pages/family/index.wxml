<!--pages/family/index.wxml-->
<view class="container">

  <!-- 1. 顶部提示语 -->
  <view class="tip-banner">
    ☁️ 协同共享机制开启后，您和爱人的设备将全部挂接同一个云端宝宝数据库。任何一方记录的便便、饮奶、用药及儿保打卡，另一方点击页面即可实时同步获取。
  </view>

  <!-- ==================== 情况A: 已绑定家庭组 ==================== -->
  <view wx:if="{{ myFamilyId }}">
    
    <!-- 家庭概览 Card -->
    <view class="card family-active-card">
      <view class="family-badge">🏡 共享家庭进行中</view>
      <view class="baby-name-row">
        <text class="lbl">关爱宝宝：</text>
        <text class="val">{{ familyDetails.baby_name || '未录入' }}</text>
      </view>
      
      <!-- 邀请码展示框 -->
      <view class="invite-display-box">
        <view class="code-header">
          <text class="lbl">家庭同步码 (长按/点击复制)</text>
          <view class="code-actions">
            <text class="btn-action" bindtap="copyInviteCode">📋 复制</text>
            <text class="btn-action btn-qr-action" bindtap="openQrModal">🖼️ 二维码</text>
          </view>
        </view>
        <text class="code-val" bindtap="copyInviteCode">{{ myFamilyId }}</text>
      </view>

      <view class="hint-msg">把这串同步码发送给家人，或让家人使用“扫码绑定”直接扫二维码加入。</view>
    </view>

    <!-- 看护人列表 Card -->
    <view class="card">
      <view class="section-title">👥 家庭守护成员 ({{ membersList.length }}人)</view>
      <view class="members-flow">
        <block wx:for="{{ membersList }}" wx:key="openid">
          <view class="member-row-item">
            <image class="member-avatar-img" src="{{ item.avatarUrl || '/assets/avatar_default.png' }}" mode="aspectFill"></image>
            <view class="member-meta">
              <view class="member-nickname-row">
                <text class="member-nickname">{{ item.nickName || '看护人' }}</text>
                <text class="member-role-badge {{ item.openid === familyDetails.creator_openid ? 'role-creator' : 'role-helper' }}">
                  {{ item.openid === familyDetails.creator_openid ? '创建者' : '看护人' }}
                </text>
              </view>
              <text class="member-openid-sub">ID: {{ item.openid || '未知' }}</text>
            </view>
          </view>
        </block>
      </view>
    </view>

    <!-- 解绑退出按钮 -->
    <button class="btn btn-danger btn-block" style="margin-top: 40rpx;" bindtap="leaveFamily">
      📴 退出/解绑当前家庭组
    </button>
  </view>


  <!-- ==================== 情况B: 未绑定家庭组 ==================== -->
  <view wx:else>
    
    <!-- 方案1：我是管理员，创建家庭 -->
    <view class="card create-card-box">
      <view class="section-title">🏡 方式一：我是创建者</view>
      <text class="card-desc">如果您是第一次使用本小程序并负责记录，请点击下方按钮开通全新的家庭空间。开通后系统会自动为您复制同步码。</text>
      <button class="btn btn-primary btn-block" bindtap="createFamily">
        新建家庭组并获取邀请码
      </button>
    </view>

    <!-- 分割线 -->
    <view class="divider-line">
      <view class="line"></view>
      <text class="text">或者</text>
      <view class="line"></view>
    </view>

    <!-- 方案2：爱人已建好，我来加入 -->
    <view class="card join-card-box">
      <view class="section-title">🔗 方式二：加入爱人的家庭</view>
      <text class="card-desc">如果您的家人已经开通了家庭空间并向您发送了邀请，请点击下方进行扫码绑定，或在下方输入同步码进行绑定：</text>
      
      <button class="btn btn-scan btn-block" style="margin-bottom: 24rpx;" bindtap="scanToJoin">
        📷 扫码绑定 (推荐)
      </button>

      <view class="invite-input-group">
        <input class="invite-input" type="text" placeholder="粘贴 24 位家庭同步码" value="{{ inviteCodeInput }}" bindinput="onInviteInput" />
        <button class="btn btn-orange" bindtap="joinFamily">确认绑定</button>
      </view>
    </view>

  </view>

  <!-- 二维码显示模态弹窗 -->
  <view class="qr-modal-overlay" wx:if="{{ showQrModal }}" bindtap="closeQrModal">
    <view class="qr-modal-content" catchtap="preventBubble">
      <view class="qr-modal-header">
        <text class="qr-title">👨‍👩‍👧‍👦 家庭组扫码绑定</text>
        <text class="btn-close" bindtap="closeQrModal">✕</text>
      </view>
      <view class="qr-body">
        <image class="qr-img" src="https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=familyId:{{ myFamilyId }}" show-menu-by-longpress="true" mode="aspectFit"></image>
        <text class="qr-hint">提示：长按上方二维码可以发送或保存。让爱人打开微信小程序“协同共享”，点击【扫码绑定】扫描此二维码即可快速加入。</text>
        <text class="qr-sync-code">同步码: {{ myFamilyId }}</text>
      </view>
    </view>
  </view>

</view>
