/* pages/bowel/index.wxss */

/* 今日统计卡片 */
.summary-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx;
  background: linear-gradient(135deg, #a0aec0 0%, #718096 100%);
  color: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(113, 128, 150, 0.2);
  border-radius: 20rpx;
  margin-bottom: 24rpx;
}
.summary-lbl {
  font-size: 28rpx;
  font-weight: 700;
}
.summary-val {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}
.summary-val .count {
  font-size: 56rpx;
  font-weight: 800;
  line-height: 1;
}
.summary-val .unit {
  font-size: 24rpx;
  font-weight: 600;
}

/* 表单排版 */
.form-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}
.form-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.form-item .lbl {
  font-size: 22rpx;
  color: #718096;
  font-weight: 600;
}
.form-item textarea {
  background-color: #f7f9fc;
  border: 1rpx solid #edf2f7;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 26rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 开关排版 */
.switch-item {
  justify-content: center;
}
.switch-item switch {
  margin-top: 8rpx;
}

/* 历史列表 */
.log-card {
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.log-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f7f9fc;
  padding-bottom: 16rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
  gap: 12rpx;
}
.log-date {
  font-size: 26rpx;
  font-weight: 700;
  color: #2d3748;
}
.badges-row {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}
.log-body {
  font-size: 24rpx;
  color: #718096;
  line-height: 1.5;
  background-color: #f7f9fc;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}
.log-action {
  display: flex;
  justify-content: flex-end;
}
.delete-link {
  font-size: 22rpx;
  color: #a0aec0;
}
.delete-link:hover {
  color: #e53e3e;
}
.btn-block {
  width: 100%;
}
