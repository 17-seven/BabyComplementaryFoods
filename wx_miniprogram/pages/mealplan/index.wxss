/* pages/mealplan/index.wxss */

/* 周切换头部 */
.week-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);
  border: 1rpx solid #edf2f7;
}
.arrow-btn {
  font-size: 32rpx;
  color: var(--primary-color);
  padding: 10rpx 20rpx;
  cursor: pointer;
}
.week-title {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.week-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2d3748;
}
.week-date {
  font-size: 22rpx;
  color: #a0aec0;
  margin-top: 4rpx;
}

/* 营养合规报告卡 */
.validation-card {
  border-left: 8rpx solid var(--primary-color);
}
.rule-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.rule-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
}
.rule-status {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}
.status-ok {
  background-color: var(--status-green);
  box-shadow: 0 0 0 4rpx #c6f6d5;
}
.status-warn {
  background-color: var(--status-orange);
  box-shadow: 0 0 0 4rpx #feebc8;
}
.status-err {
  background-color: var(--status-red);
  box-shadow: 0 0 0 4rpx #fed7d7;
}

/* 违规食材警告框 */
.allergen-warn-box {
  background-color: #fff5f5;
  border: 1rpx solid #fed7d7;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-top: 20rpx;
  color: #c53030;
}
.warn-title {
  font-size: 24rpx;
  font-weight: 700;
}
.warn-log {
  font-size: 22rpx;
  margin-top: 8rpx;
}

/* 每日排餐卡片流 */
.day-card {
  display: flex;
  padding: 0rpx;
  overflow: hidden;
}
.day-side {
  width: 150rpx;
  background-color: #f7f9fc;
  border-right: 1rpx solid #edf2f7;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 10rpx;
}
.day-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #2d3748;
}
.day-date {
  font-size: 20rpx;
  color: #a0aec0;
  margin-top: 8rpx;
}

.meals-side {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.meal-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 26rpx;
}
.meal-label {
  background-color: #fff5f2;
  color: var(--accent-orange);
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 600;
}
.meal-name {
  color: #4a5568;
  font-weight: 500;
}

/* 鸡蛋配额 */
.egg-target-hint {
  font-size: 22rpx;
  color: #718096;
  border-top: 1rpx dashed #edf2f7;
  padding-top: 12rpx;
  margin-top: 4rpx;
}
.egg-target-hint .highlight {
  color: var(--accent-orange);
  font-weight: 700;
}
