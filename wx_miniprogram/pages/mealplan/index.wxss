/* pages/mealplan/index.wxss */

/* 周切换头部 */
.week-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);
  border: 1rpx solid #edf2f7;
}
.arrow-btn {
  font-size: 32rpx;
  color: var(--primary-color);
  padding: 10rpx 20rpx;
  cursor: pointer;
}
.week-title {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.week-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2d3748;
}
.week-date {
  font-size: 22rpx;
  color: #a0aec0;
  margin-top: 4rpx;
}

/* 营养合规报告卡 */
.validation-card {
  border-left: 8rpx solid var(--primary-color);
}
.rule-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.rule-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
}
.rule-status {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}
.status-ok {
  background-color: var(--status-green);
  box-shadow: 0 0 0 4rpx #c6f6d5;
}
.status-warn {
  background-color: var(--status-orange);
  box-shadow: 0 0 0 4rpx #feebc8;
}
.status-err {
  background-color: var(--status-red);
  box-shadow: 0 0 0 4rpx #fed7d7;
}

/* 违规食材警告框 */
.allergen-warn-box {
  background-color: #fff5f5;
  border: 1rpx solid #fed7d7;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-top: 20rpx;
  color: #c53030;
}
.warn-title {
  font-size: 24rpx;
  font-weight: 700;
}
.warn-log {
  font-size: 22rpx;
  margin-top: 8rpx;
}

/* 每日排餐卡片流 */
.day-card {
  display: flex;
  padding: 0rpx;
  overflow: hidden;
}
.day-side {
  width: 150rpx;
  background-color: #f7f9fc;
  border-right: 1rpx solid #edf2f7;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 10rpx;
}
.day-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #2d3748;
}
.day-date {
  font-size: 20rpx;
  color: #a0aec0;
  margin-top: 8rpx;
}

.meals-side {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.meal-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 26rpx;
}
.meal-label {
  background-color: #fff5f2;
  color: var(--accent-orange);
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 600;
}
.meal-name {
  color: #4a5568;
  font-weight: 500;
}

/* 鸡蛋配额 */
.egg-target-hint {
  font-size: 22rpx;
  color: #718096;
  border-top: 1rpx dashed #edf2f7;
  padding-top: 12rpx;
  margin-top: 4rpx;
}
.egg-target-hint .highlight {
  color: var(--accent-orange);
  font-weight: 700;
}

/* 每日大备注 */
.day-note-row {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
  padding-top: 10rpx;
  border-top: 1rpx dashed #edf2f7;
  font-size: 22rpx;
}
.note-label {
  color: #718096;
  font-weight: 600;
  flex-shrink: 0;
}
.note-input {
  flex: 1;
  color: #4a5568;
  font-size: 22rpx;
  height: 36rpx;
  min-height: 36rpx;
}
.note-placeholder {
  color: #cbd5e0;
  font-size: 20rpx;
}

/* 顶部规则校验合规 Banner 样式 */
.compliance-banner {
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  font-size: 24rpx;
  line-height: 1.5;
  border-width: 1rpx;
  border-style: solid;
}
.banner-ok {
  background-color: #f0fdf4;
  color: #166534;
  border-color: #bbf7d0;
}
.banner-err {
  background-color: #fef2f2;
  color: #991b1b;
  border-color: #fca5a5;
}
.compliance-message {
  white-space: pre-wrap;
  word-break: break-all;
}

/* 登录提示 Banner */
.login-tip-banner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #fffaf0;
  border: 1rpx solid #feebc8;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 20rpx;
}
.tip-content {
  display: flex;
  align-items: center;
  flex: 1;
}
.tip-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}
.tip-text {
  font-size: 22rpx;
  color: #dd6b20;
  font-weight: 500;
}
.btn-login-inline {
  font-size: 20rpx;
  color: #ffffff;
  background-color: var(--accent-orange);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  margin: 0;
  line-height: 1.5;
  font-weight: 600;
  border: none;
}

/* 智能操作 Bar */
.recipe-action-card {
  padding: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: center;
}
.btn-recipe-action {
  width: 100% !important;
  background-color: var(--primary-color);
  color: #ffffff;
  font-size: 26rpx;
  border-radius: 12rpx;
  font-weight: 600;
  padding: 12rpx 0;
  line-height: 1.8;
}

/* 已过期的卡片及元素样式 */
.day-card-passed {
  background-color: #f5f7fa !important;
}
.day-card-passed .day-side {
  background-color: #eef2f6 !important;
}
.passed-check {
  color: #38a169;
  font-weight: bold;
  font-size: 30rpx;
}
.egg-target-hint.disabled {
  color: #a0aec0;
}
.egg-target-hint.disabled .highlight {
  color: #a0aec0;
}
.note-input[disabled] {
  color: #a0aec0;
}


