<!--pages/mealplan/index.wxml-->
<view class="container page-anim-{{ animKey }}">
  
  <!-- 1. 顶部切换栏 -->
  <view class="week-header">
    <view class="arrow-btn" bindtap="switchWeek" data-dir="prev">◀</view>
    <view class="week-title">
      <text class="week-name">{{ currentWeek.week }}</text>
      <text class="week-date">{{ currentWeekPeriodChinese }}</text>
    </view>
    <view class="arrow-btn" bindtap="switchWeek" data-dir="next">▶</view>
  </view>

  <!-- 登录提示 Banner -->
  <view class="login-tip-banner" wx:if="{{ !isLoggedIn }}">
    <view class="tip-content">
      <text class="tip-icon">💡</text>
      <text class="tip-text">提示：登录后可自动生成并备份本周食谱。</text>
    </view>
    <button class="btn-login-inline" bindtap="goToLogin">去登录</button>
  </view>

  <!-- 本周食谱智能操作 Bar -->
  <view class="recipe-action-card card">
    <button class="btn-recipe-action" bindtap="triggerRecipeGeneration">
      {{ isWeekGenerated ? '🔄 重置本周食谱' : '✨ 智能生成本周食谱' }}
    </button>
  </view>

  <!-- 2. 营养校验 Card -->
  <view class="card validation-card">
    <view class="section-title">
      <text>📊 本周营养校验合规报告</text>
    </view>
    
    <!-- 动态合规反馈 Banner -->
    <view class="compliance-banner {{ rules.passed ? 'banner-ok' : 'banner-err' }}">
      <text class="compliance-message">{{ rules.message }}</text>
    </view>
    
    <view class="rule-list">
      <view class="rule-item">
        <view class="rule-status {{ rules.meatPassed ? 'status-ok' : 'status-err' }}"></view>
        <text class="rule-text">红肉摄入 (猪/牛 ≥5次)：{{ rules.meatCount }} 次</text>
      </view>

      <view class="rule-item">
        <view class="rule-status {{ rules.fishShrimpLiverPassed ? 'status-ok' : 'status-err' }}"></view>
        <text class="rule-text">鱼/虾/鹅肝交替 (2-3次)：{{ rules.fishShrimpLiverCount }} 次</text>
      </view>

      <view class="rule-item">
        <view class="rule-status {{ rules.grainPassed ? 'status-ok' : 'status-warn' }}"></view>
        <text class="rule-text">粗粮占比 (建议不超过30%)：已占 {{ rules.grainPercent }}%</text>
      </view>

      <view class="rule-item">
        <view class="rule-status {{ rules.eggPassed ? 'status-ok' : 'status-err' }}"></view>
        <text class="rule-text">每日吃蛋天数：{{ rules.eggDays }} 天</text>
      </view>

      <view class="rule-item">
        <view class="rule-status {{ rules.namingPassed ? 'status-ok' : 'status-err' }}"></view>
        <text class="rule-text">菜品命名规范度：{{ rules.namingPassed ? '合规' : '不合规 (禁止使用 + 拼接)' }}</text>
      </view>

      <view class="rule-item">
        <view class="rule-status {{ rules.allergenPassed ? 'status-ok' : 'status-err' }}"></view>
        <text class="rule-text">未排敏食材防护：{{ rules.allergenPassed ? '未发现违规食材' : '检测到未排敏食物' }}</text>
      </view>
    </view>

    <!-- 违禁食品警示 -->
    <view class="allergen-warn-box" wx:if="{{ !rules.allergenPassed }}">
      <view class="warn-title">⚠️ 警告：检测到未排敏食材引入</view>
      <block wx:for="{{ rules.allergenLogs }}" wx:key="index">
        <view class="warn-log">{{ item }}</view>
      </block>
    </view>
  </view>

  <!-- 3. 周历食谱卡片流 -->
  <view class="section-title">
    <text>📅 周日计划食谱</text>
  </view>

  <block wx:for="{{ currentWeek.days }}" wx:key="date">
    <view class="card day-card {{ item.isPassed ? 'day-card-passed' : '' }}">
      <view class="day-side">
        <view class="day-name-wrapper" style="display: flex; align-items: center; justify-content: center; gap: 4rpx;">
          <text class="passed-check" wx:if="{{ item.isPassed }}">✓</text>
          <text class="day-name">{{ item.dayName }}</text>
        </view>
        <text class="day-date">{{ item.date }}</text>
      </view>
      
      <view class="meals-side">
        <block wx:for="{{ item.meals }}" wx:for-item="meal" wx:key="type">
          <view class="meal-row" bindtap="{{ item.isPassed ? '' : 'editMeal' }}" data-date="{{ item.date }}" data-mealtype="{{ meal.type }}" data-name="{{ meal.name }}">
            <text class="meal-label">{{ meal.type }}</text>
            <text class="meal-name">{{ meal.name || (item.isPassed ? '未录入' : '点击录入辅食菜品...') }} <text wx:if="{{ !item.isPassed }}">✍️</text></text>
          </view>
        </block>
        
        <!-- 每日鸡蛋目标提示 -->
        <view class="egg-target-hint {{ item.isPassed ? 'disabled' : '' }}" bindtap="{{ item.isPassed ? '' : 'adjustEggTarget' }}" data-date="{{ item.date }}" data-current="{{ item.eggTarget }}">
          🥚 今日鸡蛋配额：<text class="highlight">{{ item.eggTarget }} 个 <text wx:if="{{ !item.isPassed }}" class="edit-link">(点击修改)</text></text>
        </view>
 
        <!-- 每日大备注栏 -->
        <view class="day-note-row">
          <text class="note-label">📝 备注：</text>
          <input class="note-input" type="text" placeholder="{{ item.isPassed ? '无备注' : '记录今日喂养状态、便便情况等...' }}" value="{{ notes[item.date] || '' }}" bindinput="updateDayNote" data-date="{{ item.date }}" placeholder-class="note-placeholder" disabled="{{ item.isPassed }}" />
        </view>
      </view>
    </view>
  </block>

  <!-- 4. 底部创建下周计划操作 -->
  <view class="fixed-bottom-action" style="padding: 20rpx 0 60rpx;">
    <button class="btn btn-outline-primary btn-block" bindtap="addNewWeek">
      ➕ 新增并规划下周辅食菜单
    </button>
  </view>

</view>
