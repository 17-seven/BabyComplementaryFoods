/* pages/login/index.wxss */
.login-page {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  box-sizing: border-box;
}

.bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 1;
}

/* 内容覆盖容器 */
.content-container {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 52vh; /* 精准定位高度，恰好契合底图白色卡片的位置 */
  z-index: 2;
  box-sizing: border-box;
}

/* 白色底座卡片 (完全透明以透出背景图自带的白色区域，且内容完全垂直与水平居中) */
.login-card {
  width: 100%;
  height: 100%;
  background-color: transparent;
  padding: 40rpx 50rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

/* 欢迎回来 */
.welcome-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.welcome-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #38a169;
  letter-spacing: 2rpx;
}

.leaf-emoji {
  font-size: 44rpx;
}

.welcome-subtitle {
  font-size: 26rpx;
  color: #718096;
  margin-top: 18rpx;
  font-weight: 500;
  text-align: center;
}

/* 微信一键登录圆弧大按钮 */
.btn-wechat {
  background: linear-gradient(135deg, #76b852 0%, #8DC26F 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 50rpx;
  padding: 26rpx 0;
  text-align: center;
  width: 90%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 10rpx 24rpx rgba(118, 184, 82, 0.25);
  margin-top: 48rpx;
  border: none;
  line-height: 1.5;
}
.btn-wechat:active {
  transform: scale(0.985);
  opacity: 0.95;
}

.wechat-svg-icon {
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
  filter: brightness(0) invert(1); /* 借助 CSS 滤镜将黑色填充的反转为白透，贴合深绿色胶囊按钮 */
}

/* 协议条款勾选 (紧随微信登录按钮之后，垂直方向完全居中) */
.agreement-row {
  margin-top: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #718096;
  gap: 10rpx;
  padding: 0 20rpx;
  text-align: center;
}

.agreement-checkbox {
  transform: scale(0.7);
}

.agreement-text {
  line-height: 1.5;
}

.link-text {
  color: #38a169;
  font-weight: 600;
  display: inline;
}

/* 完善资料半屏抽屉 */
.half-screen-drawer {
  position: fixed;
  inset: 0;
  z-index: 100;
  visibility: hidden;
  transition: visibility 0.3s;
}
.half-screen-drawer.show {
  visibility: visible;
}

.drawer-mask {
  position: absolute;
  inset: 0;
  background-color: rgba(0, 0, 0, 0.5);
  opacity: 0;
  transition: opacity 0.3s;
}
.half-screen-drawer.show .drawer-mask {
  opacity: 1;
}

.drawer-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #ffffff;
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  padding: 40rpx;
  box-sizing: border-box;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  box-shadow: 0 -10rpx 40rpx rgba(0, 0, 0, 0.1);
}
.half-screen-drawer.show .drawer-content {
  transform: translateY(0);
}

.drawer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.drawer-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #2d3748;
}
.drawer-close {
  font-size: 32rpx;
  color: #a0aec0;
  padding: 10rpx;
}

.drawer-hint {
  font-size: 24rpx;
  color: #718096;
  line-height: 1.5;
}

.form-panel {
  margin-top: 30rpx;
  background-color: #f7f9fc;
  border-radius: 20rpx;
  padding: 30rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}
.form-item:last-child {
  margin-bottom: 0;
}

.field-label {
  font-size: 22rpx;
  color: #4a5568;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.avatar-item {
  align-items: center;
}

.avatar-btn {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 120rpx !important;
  height: 120rpx !important;
  min-width: 120rpx !important;
  min-height: 120rpx !important;
  border-radius: 50% !important;
  padding: 0;
  margin: 0;
  border: 2rpx solid #edf2f7;
  overflow: hidden;
  background-color: #ffffff;
  box-sizing: border-box;
}
.avatar-btn::after {
  border: none;
}
.avatar-img {
  width: 100%;
  height: 100%;
}
.avatar-tip {
  font-size: 18rpx;
  color: #a0aec0;
  margin-top: 8rpx;
}

.nickname-input {
  background-color: #ffffff;
  border: 2rpx solid #edf2f7;
  border-radius: 16rpx;
  height: 88rpx;
  min-height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #2d3748;
  width: 100%;
  box-sizing: border-box;
}

.btn-submit {
  background: linear-gradient(135deg, #76b852 0%, #8DC26F 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 16rpx;
  padding: 20rpx 0;
  text-align: center;
  margin-top: 30rpx;
  width: 100%;
  border: none;
  line-height: 1.5;
}
.btn-submit:active {
  transform: scale(0.985);
  opacity: 0.95;
}
