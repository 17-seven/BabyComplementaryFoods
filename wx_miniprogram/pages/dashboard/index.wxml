<!--pages/dashboard/index.wxml-->
<view class="container page-anim-{{ animKey }}">
  
  <!-- 未登录柔和提示条（非强制，用户可忽略继续浏览） -->
  <view class="login-hint-bar" wx:if="{{ !isLoggedIn }}" bindtap="goToLogin">
    <text class="login-hint-text">💡 登录后可开启多端同步与家庭协同 →</text>
  </view>

  <!-- 1. 宝宝名片 Card -->
  <view class="baby-card">
    <view class="baby-header">
      <image class="avatar" src="{{ avatarUrl }}" mode="aspectFill" bindtap="onAvatarTap" />
      <view class="baby-meta">
        <view class="name-row">
          <text class="name">{{ babyInfo.name }}</text>
          <text class="gender-icon">👶</text>
        </view>
        <text class="birth-desc">出生：{{ babyInfo.birthDate || '未设置' }}</text><text class="birth-desc" wx:if="{{ babyInfo.desc }}"> ({{ babyInfo.desc }})</text>
      </view>
    </view>
    <!-- 早产宝宝展示双月龄，非早产只展示实际月龄 -->
    <view class="age-row" wx:if="{{ isPremature }}">
      <view class="age-box">
        <text class="age-lbl">实际月龄</text>
        <text class="age-val">{{ actualAge }}</text>
      </view>
      <view class="age-line"></view>
      <view class="age-box">
        <text class="age-lbl">纠正月龄</text>
        <text class="age-val">{{ correctedAge || '未到纠正预产期' }}</text>
      </view>
    </view>
    <view class="age-row" wx:else>
      <view class="age-box" style="flex:1;">
        <text class="age-lbl">实际月龄</text>
        <text class="age-val">{{ actualAge }}</text>
      </view>
    </view>
  </view>

  <!-- 2. 重要提醒 Card -->
  <view class="section-title">
    <text>🔔 重要提醒</text>
  </view>
  
  <view class="reminder-container" wx:if="{{ nextVaccine || nextCheckup || nextClinical }}">
    <!-- 疫苗提醒 -->
    <view class="alert-box alert-red" wx:if="{{ nextVaccine }}" bindtap="toHealthcare">
      <view class="alert-icon">💉</view>
      <view class="alert-body">
        <view class="alert-title">下一针补种疫苗：{{ nextVaccine.name }} ({{ nextVaccine.dose }})</view>
        <view class="alert-desc">还有 <text class="alert-highlight">{{ nextVaccine.daysLeft }}</text> 天 | 预计接种日：{{ nextVaccine.plannedDate }}</view>
      </view>
    </view>

    <!-- 儿保提醒 -->
    <view class="alert-box alert-orange" wx:if="{{ nextCheckup }}" bindtap="toHealthcare">
      <view class="alert-icon">🩺</view>
      <view class="alert-body">
        <view class="alert-title">下一次季度儿保体检</view>
        <view class="alert-desc">还有 <text class="alert-highlight">{{ nextCheckup.daysLeft }}</text> 天 | 建议体检日：{{ nextCheckup.plannedDate }}</view>
      </view>
    </view>

    <!-- 临床就诊提醒 -->
    <view class="alert-box alert-blue" wx:if="{{ nextClinical }}" bindtap="toHealthcare">
      <view class="alert-icon">📅</view>
      <view class="alert-body">
        <view class="alert-title">下一次就诊检查预约：{{ nextClinical.name }}</view>
        <view class="alert-desc">还有 <text class="alert-highlight">{{ nextClinical.daysLeft }}</text> 天 | 预约时间：{{ nextClinical.date }}</view>
      </view>
    </view>
  </view>
  <view class="empty-placeholder" wx:else>当前暂无就诊或接种日程计划 🍃</view>

  <!-- 3. 今日护理概览 Grid -->
  <view class="section-title">
    <text>📈 今日护理概览</text>
  </view>

  <view class="gauge-grid">
    <view class="gauge-card" bindtap="toNutrition">
      <view class="gauge-ring ring-green">
        <text class="gauge-num">{{ milkVal }}</text>
        <text class="gauge-unit">ml</text>
      </view>
      <text class="gauge-name">饮奶量 (目标500) ➔</text>
    </view>

    <view class="gauge-card" bindtap="toNutrition">
      <view class="gauge-ring ring-blue">
        <text class="gauge-num">{{ waterVal }}</text>
        <text class="gauge-unit">ml</text>
      </view>
      <text class="gauge-name">饮水量 ➔</text>
    </view>

    <view class="gauge-card" bindtap="toBowel">
      <view class="gauge-ring ring-teal">
        <text class="gauge-num">{{ bowelCount }}</text>
        <text class="gauge-unit">次</text>
      </view>
      <text class="gauge-name">排便次数 ➔</text>
    </view>

    <view class="gauge-card" bindtap="toSleep">
      <view class="gauge-ring ring-purple">
        <text class="gauge-num">{{ sleepVal }}</text>
        <text class="gauge-unit">h</text>
      </view>
      <text class="gauge-name">😴 睡眠 ({{ sleepTarget }}h) ➔</text>
    </view>

    <!-- 可扩展计时项（来自 vision_timer_items） -->
    <block wx:for="{{ timerItems }}" wx:key="id">
      <view class="gauge-card" bindtap="toVision">
        <view class="gauge-ring ring-orange">
          <text class="gauge-num">{{ item.todayHours }}</text>
          <text class="gauge-unit">h</text>
        </view>
        <text class="gauge-name">{{ item.icon }}{{ item.name }} ({{ item.targetHours }}h) ➔</text>
      </view>
    </block>
  </view>

  <!-- 本周趋势 -->
  <view class="section-title" wx:if="{{ weekStats.length > 0 }}"><text>📊 本周趋势</text></view>
  <view class="card week-chart-card" wx:if="{{ weekStats.length > 0 }}">
    <view class="wc-row">
      <text class="wc-label">🍼 奶量(ml)</text>
      <view class="wc-bars">
        <view class="wc-col" wx:for="{{ weekStats }}" wx:key="date">
          <view class="wc-bar-wrap"><view class="wc-bar wc-milk" style="height: {{ item.milkH }}rpx;"></view></view>
          <text class="wc-day">{{ item.label }}</text>
          <text class="wc-val">{{ item.milk }}</text>
        </view>
      </view>
    </view>
    <view class="wc-row wc-divider">
      <text class="wc-label">💧 水量(ml)</text>
      <view class="wc-bars">
        <view class="wc-col" wx:for="{{ weekStats }}" wx:key="date">
          <view class="wc-bar-wrap"><view class="wc-bar wc-water" style="height: {{ item.waterH }}rpx;"></view></view>
          <text class="wc-day">{{ item.label }}</text>
          <text class="wc-val">{{ item.water }}</text>
        </view>
      </view>
    </view>
    <view class="wc-row wc-divider">
      <text class="wc-label">💩 排便(次)</text>
      <view class="wc-bars">
        <view class="wc-col" wx:for="{{ weekStats }}" wx:key="date">
          <view class="wc-bar-wrap"><view class="wc-bar wc-bowel" style="height: {{ item.bowelH }}rpx;"></view></view>
          <text class="wc-day">{{ item.label }}</text>
          <text class="wc-val">{{ item.bowel }}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 4. 最近大事记 -->
  <view class="section-title" bindtap="toTimeline">
    <text>🏆 最近大事记</text>
    <text class="arrow-more">查看更多 ➔</text>
  </view>

  <view class="card milestone-card" wx:if="{{ latestMilestone }}" bindtap="toTimeline">
    <view class="milestone-header">
      <view class="milestone-badge">{{ latestMilestone.category }}</view>
      <text class="milestone-date">{{ latestMilestone.date }}</text>
    </view>
    <view class="milestone-body">
      <text class="milestone-title">{{ latestMilestone.title }}</text>
      <text class="milestone-content">{{ latestMilestone.content }}</text>
    </view>
  </view>
  <view class="empty-placeholder" wx:else>暂无大事记记录 📝</view>

</view>
