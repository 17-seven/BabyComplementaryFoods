/* pages/dashboard/index.wxss */

/* 未登录柔和提示条 */
.login-hint-bar {
  background-color: #fffbeb;
  border: 1rpx solid #fbd38d;
  border-radius: 16rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}
.login-hint-text {
  font-size: 24rpx;
  color: #b7791f;
  font-weight: 500;
}

/* 宝宝名片渐变卡片 */
.baby-card {
  background: linear-gradient(135deg, #ff9e80 0%, #ff7043 100%);
  color: #ffffff;
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 112, 67, 0.25);
}
.baby-header {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}
.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  margin-right: 20rpx;
  background-color: #f7f9fc;
}
.baby-meta {
  display: flex;
  flex-direction: column;
}
.name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.name {
  font-size: 36rpx;
  font-weight: 700;
}
.gender-icon {
  font-size: 32rpx;
}
.birth-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 4rpx;
}

/* 月龄网格 */
.age-row {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 16rpx 0;
}
.age-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}
.age-lbl {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
}
.age-val {
  font-size: 28rpx;
  font-weight: 700;
  margin-top: 4rpx;
}
.age-line {
  width: 1rpx;
  height: 48rpx;
  background-color: rgba(255, 255, 255, 0.25);
}

/* 重要提醒排版 */
.reminder-container {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 30rpx;
}
.alert-box {
  display: flex;
  align-items: center;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid transparent;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.01);
}
.alert-icon {
  font-size: 38rpx;
  margin-right: 18rpx;
}
.alert-body {
  flex: 1;
}
.alert-title {
  font-size: 24rpx;
  font-weight: 700;
}
.alert-desc {
  font-size: 22rpx;
  margin-top: 4rpx;
}
.alert-highlight {
  font-weight: 700;
}

/* 警示框三色定义 */
.alert-red {
  background-color: #fff5f5;
  border-color: #fed7d7;
  color: #c53030;
}
.alert-red .alert-highlight {
  color: #e53e3e;
}
.alert-orange {
  background-color: #fffaf0;
  border-color: #feebc8;
  color: #dd6b20;
}
.alert-orange .alert-highlight {
  color: #dd6b20;
}
.alert-blue {
  background-color: #ebf8ff;
  border-color: #bee3f8;
  color: #2b6cb0;
}
.alert-blue .alert-highlight {
  color: #2b6cb0;
}

/* 今日护理网格 */
.gauge-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 30rpx;
}
.gauge-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);
  border: 1rpx solid #edf2f7;
}
.gauge-ring {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  margin-bottom: 16rpx;
  border: 8rpx solid #edf2f7;
}
.gauge-num {
  font-size: 36rpx;
  font-weight: 700;
}
.gauge-unit {
  font-size: 18rpx;
  color: #718096;
}
.gauge-name {
  font-size: 22rpx;
  color: #718096;
  font-weight: 500;
}

/* 环形边框颜色 */
.ring-green { border-color: #c6f6d5; color: #2f855a; }
.ring-blue { border-color: #bee3f8; color: #2b6cb0; }
.ring-teal { border-color: #e6fffa; color: #319795; }
.ring-orange { border-color: #feebc8; color: #dd6b20; }

/* 大事记卡片 */
.arrow-more {
  font-size: 24rpx;
  color: var(--primary-color);
  font-weight: 500;
  margin-left: auto;
}
.milestone-card {
  padding: 28rpx;
  background-color: #ffffff;
}
.milestone-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.milestone-badge {
  font-size: 20rpx;
  background-color: #ebf8ff;
  color: #2b6cb0;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 600;
}
.milestone-date {
  font-size: 22rpx;
  color: #a0aec0;
}
.milestone-body {
  display: flex;
  flex-direction: column;
}
.milestone-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2d3748;
}
.milestone-content {
  font-size: 24rpx;
  color: #718096;
  margin-top: 6rpx;
  line-height: 1.5;
}
