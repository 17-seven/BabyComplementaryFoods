<!--pages/nutrition/index.wxml-->
<view class="container">
  
  <!-- 1. 指标看板 Grid -->
  <view class="progress-summary-grid">
    <view class="card summary-card milk-card-bg">
      <view class="card-header">
        <text class="card-icon">🍼</text>
        <text class="card-title">今日饮奶量</text>
      </view>
      <view class="val-wrapper">
        <text class="val-num text-green">{{ todayMilk }}</text>
        <text class="val-unit">ml / 500ml</text>
      </view>
      <view class="progress-bar-container">
        <view class="progress-bar bg-green" style="width: {{ milkProgressPercent }}%"></view>
      </view>
      <text class="warn-tip" wx:if="{{ todayMilk > 500 }}">⚠️ 已超医嘱 500ml 限制</text>
    </view>

    <view class="card summary-card water-card-bg">
      <view class="card-header">
        <text class="card-icon">💧</text>
        <text class="card-title">今日饮水量</text>
      </view>
      <view class="val-wrapper">
        <text class="val-num text-blue">{{ todayWater }}</text>
        <text class="val-unit">ml</text>
      </view>
    </view>
  </view>

  <!-- 2. 快捷加量打卡 -->
  <view class="section-title">⚡ 快捷记账</view>
  
  <view class="card quick-action-card">
    <view class="quick-section-title">🍼 饮奶快速打卡</view>
    <view class="quick-btn-grid">
      <view class="quick-add-btn btn-green-style" hover-class="btn-hover" bindtap="quickAdd" data-type="milk" data-amount="50">+50ml</view>
      <view class="quick-add-btn btn-green-style" hover-class="btn-hover" bindtap="quickAdd" data-type="milk" data-amount="100">+100ml</view>
      <view class="quick-add-btn btn-green-style" hover-class="btn-hover" bindtap="quickAdd" data-type="milk" data-amount="150">+150ml</view>
    </view>

    <view class="quick-section-title" style="margin-top:32rpx">💧 饮水快速打卡</view>
    <view class="quick-btn-grid">
      <view class="quick-add-btn btn-blue-style" hover-class="btn-hover" bindtap="quickAdd" data-type="water" data-amount="20">+20ml</view>
      <view class="quick-add-btn btn-blue-style" hover-class="btn-hover" bindtap="quickAdd" data-type="water" data-amount="30">+30ml</view>
      <view class="quick-add-btn btn-blue-style" hover-class="btn-hover" bindtap="quickAdd" data-type="water" data-amount="50">+50ml</view>
    </view>
  </view>

  <!-- 3. 手动录入记录表单 -->
  <view class="card form-card">
    <view class="section-title-form">➕ 补录数值</view>
    
    <!-- 分段选项卡选择类型 -->
    <view class="type-segmented-control">
      <view class="type-segment-item {{ selectedType === 'milk' ? 'active' : '' }}" hover-class="btn-hover" bindtap="selectType" data-type="milk">🍼 饮奶</view>
      <view class="type-segment-item {{ selectedType === 'water' ? 'active' : '' }}" hover-class="btn-hover" bindtap="selectType" data-type="water">💧 饮水</view>
    </view>

    <view class="form-grid">
      <view class="form-item">
        <text class="lbl">记录日期</text>
        <picker mode="date" value="{{ logDate }}" bindchange="onDateChange">
          <view class="date-picker-btn">{{ logDate }}</view>
        </picker>
      </view>

      <view class="form-item">
        <text class="lbl">容量 (ml)</text>
        <input type="number" placeholder="如 120" value="{{ amountVal }}" bindinput="onAmountInput" placeholder-class="input-placeholder" />
      </view>
    </view>

    <view class="save-btn" hover-class="btn-hover" bindtap="saveRecord">保存记录</view>
  </view>

  <!-- 4. 历史记录台账 -->
  <view class="section-title">📜 历史饮水饮奶记录</view>
  <view class="history-list">
    <block wx:for="{{ historyLogs }}" wx:key="id">
      <view class="log-card-new {{ item.type === 'milk' ? 'border-milk' : 'border-water' }}">
        <view class="log-left">
          <view class="log-type-tag {{ item.type === 'milk' ? 'tag-milk' : 'tag-water' }}">
            {{ item.type === 'milk' ? '🍼 饮奶' : '💧 饮水' }}
          </view>
          <view class="log-time-desc">
            <text class="log-date">{{ item.date }}</text>
            <text class="remark-span" wx:if="{{ item.remark }}"> ({{ item.remark }})</text>
          </view>
        </view>
        <view class="log-right">
          <text class="log-amt-text {{ item.type === 'milk' ? 'text-green' : 'text-blue' }}">{{ item.amount }}ml</text>
          <view class="delete-icon-btn" hover-class="btn-hover" bindtap="deleteLog" data-id="{{ item.id }}">
            <text class="delete-icon">🗑️</text>
          </view>
        </view>
      </view>
    </block>
  </view>

</view>
