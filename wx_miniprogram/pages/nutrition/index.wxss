/* pages/nutrition/index.wxss */

/* 看板排版 */
.progress-summary-card {
  padding: 32rpx;
}
.tracker-row {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}
.tracker-item {
  display: flex;
  flex-direction: column;
}
.tracker-item .lbl {
  font-size: 26rpx;
  color: #718096;
  font-weight: 600;
}
.val-box {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-top: 8rpx;
  margin-bottom: 12rpx;
}
.val-box .val {
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1;
}
.val-box .unit {
  font-size: 22rpx;
  color: #a0aec0;
  font-weight: 600;
}
.warn-tip {
  font-size: 20rpx;
  color: #e53e3e;
  font-weight: 700;
  margin-top: 8rpx;
}

/* 进度条 */
.progress-bar-container {
  width: 100%;
  height: 12rpx;
  background-color: #edf2f7;
  border-radius: 6rpx;
  overflow: hidden;
}
.progress-bar {
  height: 100%;
  border-radius: 6rpx;
}
.bg-green { background-color: var(--primary-color); }
.text-green { color: var(--primary-color); }
.text-blue { color: #3182ce; }

/* 快捷按钮网格 */
.quick-btn-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 16rpx;
}
.btn-blue {
  background-color: #ebf8ff;
  color: #2b6cb0;
}

/* 手动录入 */
.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.form-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}
.form-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.form-item .lbl {
  font-size: 22rpx;
  color: #718096;
  font-weight: 600;
}
.form-item input {
  background-color: #f7f9fc;
  border: 1rpx solid #edf2f7;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 26rpx;
}

/* 历史列表 */
.log-card {
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.log-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f7f9fc;
  padding-bottom: 12rpx;
  margin-bottom: 12rpx;
}
.log-date {
  font-size: 26rpx;
  font-weight: 700;
  color: #2d3748;
}
.log-amt {
  font-size: 28rpx;
  font-weight: 700;
}
.log-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.log-remark {
  font-size: 22rpx;
  color: #a0aec0;
}
.delete-link {
  font-size: 22rpx;
  color: #a0aec0;
}
.delete-link:hover {
  color: #e53e3e;
}
.btn-block {
  width: 100%;
}
.text-sm {
  font-size: 24rpx;
  color: #4a5568;
}
