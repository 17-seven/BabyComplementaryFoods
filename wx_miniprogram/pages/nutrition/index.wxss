/* pages/nutrition/index.wxss */

/* 指标看板分栏网格 */
.progress-summary-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 30rpx;
}
.summary-card {
  display: flex;
  flex-direction: column;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
  border: 1rpx solid #edf2f7;
  position: relative;
  overflow: hidden;
}
.milk-card-bg {
  background: linear-gradient(135deg, #f0fdf4 0%, #e6fffa 100%);
}
.water-card-bg {
  background: linear-gradient(135deg, #ebf8ff 0%, #eef2f6 100%);
}
.card-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.card-icon {
  font-size: 32rpx;
}
.card-title {
  font-size: 22rpx;
  color: #718096;
  font-weight: 600;
}
.val-wrapper {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  margin: 16rpx 0;
}
.val-num {
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1;
}
.val-unit {
  font-size: 20rpx;
  color: #a0aec0;
  font-weight: 600;
}
.text-green {
  color: #2f855a;
}
.text-blue {
  color: #2b6cb0;
}

/* 进度条 */
.progress-bar-container {
  width: 100%;
  height: 8rpx;
  background-color: rgba(0, 0, 0, 0.05);
  border-radius: 4rpx;
  overflow: hidden;
}
.progress-bar {
  height: 100%;
  border-radius: 4rpx;
}
.bg-green {
  background-color: #38a169;
}
.warn-tip {
  font-size: 18rpx;
  color: #e53e3e;
  font-weight: 700;
  margin-top: 10rpx;
}

/* 快捷记账卡片 */
.quick-action-card {
  padding: 28rpx 32rpx;
  margin-bottom: 30rpx;
}
.quick-section-title {
  font-size: 24rpx;
  color: #4a5568;
  font-weight: 700;
  margin-bottom: 16rpx;
}
.quick-btn-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}
.quick-add-btn {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 18rpx 0;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}
.btn-green-style {
  background-color: #e6f4ea;
  color: #137333;
}
.btn-blue-style {
  background-color: #e8f0fe;
  color: #1a73e8;
}
.btn-hover {
  opacity: 0.7;
  transform: scale(0.96);
}

/* 手动补录表单 */
.form-card {
  padding: 28rpx 32rpx;
  margin-bottom: 30rpx;
}
.section-title-form {
  font-size: 28rpx;
  font-weight: 700;
  color: #2d3748;
}

/* 分段选项卡选择器 */
.type-segmented-control {
  display: flex;
  background-color: #f1f5f9;
  border-radius: 18rpx;
  padding: 6rpx;
  margin-top: 20rpx;
  margin-bottom: 24rpx;
}
.type-segment-item {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 24rpx;
  font-weight: 600;
  color: #64748b;
  border-radius: 14rpx;
  transition: all 0.25s ease;
}
.type-segment-item.active {
  background-color: #ffffff;
  color: #334155;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 输入表单项 */
.form-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}
.form-item {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.form-item .lbl {
  font-size: 22rpx;
  color: #718096;
  font-weight: 600;
}
.date-picker-btn, .form-item input {
  background-color: #f8fafc;
  border: 1rpx solid #edf2f7;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 24rpx;
  color: #334155;
  height: 38rpx;
  line-height: 38rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}
.input-placeholder {
  color: #cbd5e0;
}
.save-btn {
  background: linear-gradient(135deg, #7cb342 0%, #689f38 100%);
  color: #ffffff;
  text-align: center;
  padding: 22rpx 0;
  font-size: 26rpx;
  font-weight: 700;
  border-radius: 20rpx;
  margin-top: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(104, 159, 56, 0.2);
  transition: all 0.2s ease;
}

/* 历史列表记录卡片 */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.log-card-new {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.01);
  border: 1rpx solid #edf2f7;
  border-left: 8rpx solid transparent;
}
.border-milk {
  border-left-color: #38a169;
}
.border-water {
  border-left-color: #3182ce;
}
.log-left {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.log-type-tag {
  align-self: flex-start;
  font-size: 18rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}
.tag-milk {
  background-color: #e6f4ea;
  color: #137333;
}
.tag-water {
  background-color: #e8f0fe;
  color: #1a73e8;
}
.log-time-desc {
  font-size: 22rpx;
  color: #718096;
  font-weight: 500;
}
.remark-span {
  color: #a0aec0;
}
.log-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.log-amt-text {
  font-size: 32rpx;
  font-weight: 800;
}
.delete-icon-btn {
  padding: 8rpx;
  opacity: 0.5;
  transition: all 0.2s ease;
}
.delete-icon {
  font-size: 26rpx;
}
