/* pages/sleep/index.wxss */
page { background: #f7f9fc; }

.container { padding: 24rpx; }

.card {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  margin-bottom: 24rpx;
  overflow: hidden;
}

/* 今日汇总 */
.today-card { padding: 32rpx; }
.today-header { display: flex; align-items: center; gap: 20rpx; margin-bottom: 20rpx; }
.today-icon { font-size: 56rpx; line-height: 1; flex-shrink: 0; }
.today-meta { flex: 1; }
.today-title { font-size: 32rpx; font-weight: 700; color: #2d3748; display: block; }
.today-sub { font-size: 22rpx; color: #a0aec0; display: block; margin-top: 4rpx; }
.today-total { text-align: right; }
.total-num { font-size: 36rpx; font-weight: 800; color: #3182ce; display: block; }
.total-pct { font-size: 22rpx; color: #718096; }
.total-done .total-num { color: #38a169; }
.progress-bar-container { height: 16rpx; background: #edf2f7; border-radius: 8rpx; overflow: hidden; }
.progress-bar { height: 100%; border-radius: 8rpx; transition: width 0.4s; }
.bar-blue { background: #3182ce; }
.bar-green { background: #38a169; }

/* 添加记录 */
.add-card { padding: 24rpx; }
.add-toggle { display: flex; align-items: center; justify-content: space-between; }
.add-toggle-label { font-size: 28rpx; font-weight: 700; color: #38a169; }
.add-toggle-chevron { font-size: 22rpx; color: #a0aec0; }
.add-form { margin-top: 24rpx; }

.form-item { margin-bottom: 20rpx; }
.lbl { font-size: 24rpx; color: #718096; display: block; margin-bottom: 10rpx; }
.form-item input {
  background: #f7f9fc; border: 1rpx solid #edf2f7; border-radius: 12rpx;
  height: 72rpx; padding: 0 20rpx; font-size: 26rpx; color: #2d3748; width: 100%;
  box-sizing: border-box;
}

.time-row { display: flex; align-items: flex-end; gap: 16rpx; }
.time-field { flex: 1; display: flex; flex-direction: column; gap: 8rpx; }
.time-arrow { font-size: 28rpx; color: #a0aec0; flex-shrink: 0; padding-bottom: 16rpx; }
.date-picker-btn {
  background: #f7f9fc; border: 1rpx solid #bee3f8; border-radius: 12rpx;
  height: 72rpx; line-height: 72rpx; padding: 0 20rpx;
  font-size: 26rpx; color: #2d3748; font-weight: 600;
}
.time-picker-btn {
  background: #f7f9fc; border: 1rpx solid #edf2f7; border-radius: 12rpx;
  height: 72rpx; line-height: 72rpx; padding: 0 20rpx;
  font-size: 26rpx; color: #a0aec0; text-align: center;
}
.has-val { color: #2d3748; font-weight: 600; border-color: #bee3f8; background: #ebf8ff; }

/* 通用按钮 */
.btn { border-radius: 14rpx; height: 88rpx; line-height: 88rpx; font-size: 28rpx; font-weight: 700; }
.btn-primary { background: #38a169; color: #fff; border: none; }
.btn-block { display: block; width: 100%; }

/* section标题 */
.section-title { font-size: 26rpx; font-weight: 700; color: #4a5568; margin-bottom: 16rpx; padding-left: 4rpx; }

/* 历史记录列表 */
.sleep-log-item {
  display: flex; align-items: center; gap: 16rpx;
  padding: 20rpx 24rpx; border-bottom: 1rpx solid #f7f9fc;
}
.sleep-log-item:last-child { border-bottom: none; }
.log-time-badge {
  background: #ebf8ff; color: #2b6cb0; font-size: 22rpx; font-weight: 700;
  padding: 8rpx 16rpx; border-radius: 12rpx; flex-shrink: 0; white-space: nowrap;
}
.log-info { flex: 1; display: flex; flex-direction: column; gap: 4rpx; min-width: 0; }
.log-date { font-size: 22rpx; color: #718096; }
.log-dur { font-size: 26rpx; font-weight: 700; color: #2d3748; }
.log-note { font-size: 20rpx; color: #a0aec0; }
.log-del { font-size: 24rpx; color: #e53e3e; padding: 8rpx 16rpx; flex-shrink: 0; }

/* 空状态 */
.empty-placeholder {
  text-align: center; color: #a0aec0; font-size: 26rpx;
  padding: 60rpx 0; display: block;
}
