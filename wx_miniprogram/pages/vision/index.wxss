/* pages/vision/index.wxss */

/* 计时仪表盘 */
.timer-dashboard {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx;
  background: #ffffff;
}
.circle-progress {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  border: 12rpx solid #e6fffa;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.01);
}
.progress-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.hours-val {
  font-size: 64rpx;
  font-weight: 800;
  color: var(--primary-color);
  line-height: 1;
}
.hours-lbl {
  font-size: 20rpx;
  color: #718096;
  margin-top: 10rpx;
  font-weight: 600;
}

/* 进度条 */
.target-lbl {
  font-size: 24rpx;
  color: #718096;
  margin-bottom: 16rpx;
  font-weight: 500;
}
.progress-bar-container {
  width: 100%;
  height: 16rpx;
  background-color: #edf2f7;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
}
.progress-bar {
  height: 100%;
  background-color: var(--primary-color);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}
.progress-text {
  font-size: 22rpx;
  color: #a0aec0;
}

/* 开关大按钮 */
.btn-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 40rpx 0;
  gap: 16rpx;
}
.timer-action-btn {
  width: 80%;
  font-size: 32rpx;
  font-weight: 700;
  padding: 24rpx 0;
  border-radius: 50rpx;
  color: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.08);
}
.active-green {
  background-color: var(--primary-color);
  box-shadow: 0 8rpx 20rpx rgba(56, 161, 105, 0.25);
}
.active-orange {
  background-color: var(--accent-orange);
  box-shadow: 0 8rpx 20rpx rgba(255, 112, 67, 0.25);
}
.status-tip {
  font-size: 22rpx;
  color: #718096;
}

/* 输入框组合 */
.input-group {
  display: flex;
  gap: 16rpx;
  align-items: center;
}
.input-group input {
  flex: 1;
  background-color: #f7f9fc;
  border: 1rpx solid #edf2f7;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 26rpx;
}

/* 历史列表 */
.log-card {
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.log-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f7f9fc;
  padding-bottom: 12rpx;
  margin-bottom: 12rpx;
}
.log-date {
  font-size: 26rpx;
  font-weight: 700;
  color: #2d3748;
}
.log-mins {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--primary-color);
}
.log-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.log-remark {
  font-size: 22rpx;
  color: #a0aec0;
}
.delete-link {
  font-size: 22rpx;
  color: #a0aec0;
}
.delete-link:hover {
  color: #e53e3e;
}
