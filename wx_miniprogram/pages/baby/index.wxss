/* pages/baby/index.wxss */

/* 顶部提示语 */
.tip-banner {
  background-color: #ebf8ff;
  color: #2b6cb0;
  font-size: 22rpx;
  padding: 18rpx 28rpx;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  line-height: 1.5;
  font-weight: 500;
  box-sizing: border-box;
}

.form-card {
  padding: 32rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.form-item .lbl {
  font-size: 26rpx;
  font-weight: 700;
  color: #2d3748;
}

.form-item input {
  background-color: #f7f9fc;
  border: 1rpx solid #edf2f7;
  border-radius: 12rpx;
  padding: 18rpx 24rpx;
  font-size: 26rpx;
  box-sizing: border-box;
  width: 100%;
}

.date-picker-btn {
  background-color: #f7f9fc;
  border: 1rpx solid #edf2f7;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #2d3748;
  text-align: left;
}

/* 开关行排版 */
.form-item-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1rpx solid #edf2f7;
  padding-top: 30rpx;
}

.row-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
  padding-right: 20rpx;
}

.row-left .lbl {
  font-size: 26rpx;
  font-weight: 700;
  color: #2d3748;
}

.sub-lbl {
  font-size: 18rpx;
  color: #a0aec0;
  font-weight: 500;
}

.hint-lbl {
  font-size: 18rpx;
  color: #dd6b20;
  line-height: 1.4;
  margin-top: 6rpx;
}

.btn-block {
  width: 100%;
}
