<!--pages/baby/index.wxml-->
<view class="container">

  <!-- 顶部提示语 -->
  <view class="tip-banner">
    📝 请录入您家宝宝的真实姓名和出生日期。如果宝宝是早产儿，请填写预产期，系统会自动计算早产天数，并以此精准校正月龄、疫苗接种及体检排班日程。
  </view>

  <view class="card form-card">
    
    <!-- 宝宝姓名 -->
    <view class="form-item">
      <text class="lbl">👶 宝宝姓名</text>
      <input type="text" placeholder="请输入宝宝姓名" value="{{ name }}" bindinput="onFieldInput" data-field="name" />
    </view>

    <!-- 出生日期 -->
    <view class="form-item" style="margin-top: 24rpx;">
      <text class="lbl">📅 出生日期（公历/实际生日）</text>
      <picker mode="date" value="{{ birthDate }}" start="2020-01-01" end="2030-12-31" bindchange="onBirthDateChange">
        <view class="date-picker-btn {{ birthDate ? '' : 'placeholder' }}">{{ birthDate || '请选择出生日期' }}</view>
      </picker>
    </view>

    <!-- 早产开关 -->
    <view class="form-item-row" style="margin-top: 36rpx;">
      <view class="row-left">
        <text class="lbl">⚠️ 是否为早产宝宝</text>
        <text class="sub-lbl">早产宝宝将按矫正胎龄智能规避不规范接种风险</text>
      </view>
      <switch checked="{{ isPremature }}" color="#38a169" bindchange="onPrematureChange" />
    </view>

    <!-- 早产细节 (早产时展示) -->
    <block wx:if="{{ isPremature }}">
      
      <!-- 预产期 -->
      <view class="form-item" style="margin-top: 24rpx;">
        <text class="lbl">🤰 预产期</text>
        <picker mode="date" value="{{ dueDate }}" start="2020-01-01" end="2030-12-31" bindchange="onDueDateChange">
          <view class="date-picker-btn {{ dueDate ? '' : 'placeholder' }}">{{ dueDate || '请选择预产期日期' }}</view>
        </picker>
        <text class="hint-lbl">选择预产期后，系统将自动计算出早产天数。</text>
      </view>

      <!-- 自动计算的早产天数（只读展示） -->
      <view class="form-item" style="margin-top: 24rpx;" wx:if="{{ prematureDays > 0 }}">
        <text class="lbl">⏳ 早产天数（自动计算）</text>
        <view class="computed-value">
          <text class="computed-number">{{ prematureDays }}</text>
          <text class="computed-unit"> 天</text>
        </view>
        <text class="hint-lbl">{{ prematureDesc }}</text>
      </view>

    </block>

  </view>

  <!-- 底部保存按钮 -->
  <button class="btn btn-primary btn-block" style="margin-top: 40rpx;" bindtap="saveProfile">
    💾 保存宝宝档案
  </button>

</view>
