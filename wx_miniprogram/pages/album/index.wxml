<!--pages/album/index.wxml-->
<view class="container">

  <!-- 1. 当前头像预览看板 -->
  <view class="card avatar-dashboard-card">
    <view class="avatar-display">
      <image class="avatar-large" src="{{ avatarUrl }}" mode="aspectFill" />
      <view class="avatar-meta">
        <text class="baby-title">王玧初 (宝宝头像)</text>
        <text class="avatar-desc">从下方相册点击任意照片，可将其快捷设为当前宝宝头像。</text>
      </view>
    </view>
  </view>

  <!-- 2. 照片网格 (最大限制 10 张) -->
  <view class="section-title">
    <text>🖼️ 宝宝成长照片柜 ({{ photos.length }}/{{ maxCount }})</text>
  </view>

  <view class="photo-grid">
    <!-- 已上传的照片列表 -->
    <block wx:for="{{ photos }}" wx:key="id">
      <view class="photo-item-box" bindtap="onPhotoTap" data-url="{{ item.url }}" data-id="{{ item.id }}">
        <image class="photo-img" src="{{ item.url }}" mode="aspectFill" />
        <!-- 当前头像标记 -->
        <view class="avatar-badge" wx:if="{{ avatarUrl === item.url }}">✓ 当前头像</view>
      </view>
    </block>

    <!-- 上传占位球 -->
    <view class="photo-upload-placeholder" bindtap="uploadPhoto" wx:if="{{ photos.length < maxCount }}">
      <text class="upload-plus">＋</text>
      <text class="upload-txt">上传照片</text>
    </view>
  </view>

  <!-- 相册满员提示 -->
  <view class="album-full-tip" wx:if="{{ photos.length >= maxCount }}">
    💡 您的宝宝相册存储空间已满 (10/10)。如果想继续上传，请轻触某张照片选择“删除照片”。
  </view>

  <!-- 首次进入提示 -->
  <view class="empty-placeholder" style="padding-top:40rpx;" wx:if="{{ photos.length === 0 }}">
    <view class="placeholder-emoji">📷</view>
    <text class="placeholder-text">相册内空空如也，赶快上传第一张宝宝萌照吧！</text>
  </view>

</view>
