/* pages/album/index.wxss */

/* 头像看板 */
.avatar-dashboard-card {
  padding: 32rpx;
  background: linear-gradient(135deg, #a8e6cf 0%, #38a169 100%);
  color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 6rpx 18rpx rgba(56, 161, 105, 0.2);
  border: none;
  margin-bottom: 30rpx;
}
.avatar-display {
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.avatar-large {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.6);
  background-color: #ffffff;
}
.avatar-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.baby-title {
  font-size: 34rpx;
  font-weight: 800;
}
.avatar-desc {
  font-size: 20rpx;
  opacity: 0.9;
  line-height: 1.4;
}

/* 照片柜网格 */
.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 24rpx;
}
.photo-item-box {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid #edf2f7;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.02);
}
.photo-img {
  width: 100%;
  height: 100%;
}

/* 头像角标 */
.avatar-badge {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(56, 161, 105, 0.85);
  color: #ffffff;
  font-size: 16rpx;
  text-align: center;
  padding: 6rpx 0;
  font-weight: 700;
}

/* 上传占位图 */
.photo-upload-placeholder {
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 16rpx;
  background-color: #ffffff;
  border: 3rpx dashed #cbd5e0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}
.upload-plus {
  font-size: 52rpx;
  color: #a0aec0;
  font-weight: 600;
  line-height: 1;
}
.upload-txt {
  font-size: 20rpx;
  color: #a0aec0;
  font-weight: 600;
}

/* 提示条 */
.album-full-tip {
  font-size: 22rpx;
  color: #dd6b20;
  background-color: #fffaf0;
  border: 1rpx solid #feebc8;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  margin-top: 10rpx;
  line-height: 1.4;
  font-weight: 500;
}
.placeholder-emoji {
  font-size: 64rpx;
  text-align: center;
}
.placeholder-text {
  font-size: 24rpx;
  color: #a0aec0;
  display: block;
  text-align: center;
}
