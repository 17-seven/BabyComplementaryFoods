/* pages/my/index.wxss */

/* 个人信息头 */
.my-profile-header {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 36rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);
  border: 1rpx solid #edf2f7;
}
.avatar-box {
  width: 100rpx;
  height: 100rpx;
  background-color: #e6fffa;
  border-radius: 50%;
  font-size: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}
.baby-info-box {
  display: flex;
  flex-direction: column;
}
.baby-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #2d3748;
}
.baby-age {
  font-size: 22rpx;
  color: #718096;
  margin-top: 8rpx;
}

/* 菜单列表 */
.menu-card-list {
  padding: 0rpx;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 24rpx;
  border-bottom: 1rpx solid #f7f9fc;
}
.menu-item:last-child {
  border-bottom: none;
}
.menu-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
}
.menu-body {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.menu-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2d3748;
}
.menu-desc {
  font-size: 20rpx;
  color: #a0aec0;
  margin-top: 6rpx;
}
.menu-arrow {
  font-size: 24rpx;
  color: #cbd5e0;
}
.menu-item:active {
  background-color: #f7f9fc;
}

/* 微信头像与文本超链接 */
.avatar-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  border: 4rpx solid #e6fffa;
}
.text-link {
  color: var(--primary-color);
  text-decoration: underline;
}

/* 弹窗遮罩 */
.modal-overlay {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.modal-card {
  width: 80%;
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.15);
}
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #edf2f7;
}
.modal-title {
  font-size: 30rpx;
  font-weight: 700;
}
.modal-close {
  font-size: 28rpx;
  color: #a0aec0;
}
.modal-body {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: stretch;
}
.form-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.form-item .lbl {
  font-size: 22rpx;
  color: #718096;
  font-weight: 600;
  margin-bottom: 8rpx;
}
.form-item input {
  background-color: #f7f9fc;
  border: 1rpx solid #edf2f7;
  border-radius: 12rpx;
  padding: 18rpx;
  font-size: 26rpx;
  box-sizing: border-box;
  width: 100%;
}
.avatar-select-item {
  align-items: center;
}
.avatar-wrapper {
  padding: 0;
  width: 130rpx !important;
  height: 130rpx !important;
  border-radius: 50%;
  background-color: #f7f9fc;
  border: 2rpx dashed #cbd5e0;
  margin-top: 10rpx;
}
.avatar-preview {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}
.modal-footer {
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #edf2f7;
}
.btn-block {
  width: 100%;
}
.hint {
  font-size: 20rpx;
  color: #a0aec0;
}

/* 底部版本号 */
.version-footer {
  text-align: center;
  padding: 40rpx 0 20rpx;
}
.version-text {
  font-size: 22rpx;
  color: #cbd5e0;
  user-select: none;
}

/* 开发者数据导入面板 */
.dev-panel {
  margin-top: 24rpx;
  padding: 28rpx;
  background-color: #fffbeb;
  border: 1rpx solid #f6e05e;
}
.dev-panel .section-title {
  font-size: 28rpx;
  color: #744210;
  margin-bottom: 12rpx;
}
.dev-hint {
  font-size: 22rpx;
  color: #975a16;
  line-height: 1.6;
  display: block;
  margin-bottom: 16rpx;
}
.dev-mapping-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  background-color: rgba(255,255,255,0.6);
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
}
.dev-mapping-item {
  font-size: 22rpx;
  color: #553c07;
  font-family: monospace;
}

/* 导入日志 */
.dev-log {
  margin-top: 16rpx;
  background-color: #1a202c;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  max-height: 400rpx;
  overflow-y: auto;
}
.dev-log-item {
  margin-bottom: 8rpx;
}
.dev-log-item:last-child {
  margin-bottom: 0;
}
.log-success {
  font-size: 22rpx;
  color: #68d391;
  font-family: monospace;
}
.log-error {
  font-size: 22rpx;
  color: #fc8181;
  font-family: monospace;
}
