<!--pages/my/index.wxml-->
<view class="container">
  
  <!-- 1. 顶部小名片 -->
  <view class="my-profile-header">
    <block wx:if="{{ isLoggedIn }}">
      <image class="avatar-img" src="{{ userInfo.avatarUrl }}" mode="aspectFill"></image>
      <view class="baby-info-box">
        <text class="baby-name">{{ userInfo.nickName }} (看护人)</text>
        <text class="baby-age">实际月龄：{{ actualAge }} | 纠正：{{ correctedAge }}</text>
      </view>
    </block>
    <block wx:else>
      <view class="avatar-box">👤</view>
      <view class="baby-info-box" bindtap="handleLogin">
        <text class="baby-name text-link">点击微信授权登录 ➔</text>
        <text class="baby-age">授权以进行云数据库同步与多端看护</text>
      </view>
    </block>
  </view>

  <!-- 2. 二级功能菜单导航流 -->
  <view class="section-title">🛠️ 宝宝日常照护快捷记账</view>
  
  <view class="card menu-card-list">
    <view class="menu-item" bindtap="navigateToPage" data-page="bowel">
      <view class="menu-icon">💩</view>
      <view class="menu-body">
        <text class="menu-title">排便与肠胃记录</text>
        <text class="menu-desc">记录每天大便次数、颜色、有无出血</text>
      </view>
      <view class="menu-arrow">➔</view>
    </view>

    <view class="menu-item" bindtap="navigateToPage" data-page="nutrition">
      <view class="menu-icon">🍼</view>
      <view class="menu-body">
        <text class="menu-title">饮奶与饮水记录</text>
        <text class="menu-desc">管理每日奶量限制、补充水分打卡</text>
      </view>
      <view class="menu-arrow">➔</view>
    </view>

    <view class="menu-item" bindtap="navigateToPage" data-page="vision">
      <view class="menu-icon">👁️</view>
      <view class="menu-body">
        <text class="menu-title">视力遮盖戴镜计时</text>
        <text class="menu-desc">记录眼罩遮盖时长，每日4小时目标打卡</text>
      </view>
      <view class="menu-arrow">➔</view>
    </view>

    <view class="menu-item" bindtap="navigateToPage" data-page="allergen">
      <view class="menu-icon">🥦</view>
      <view class="menu-body">
        <text class="menu-title">排敏食材管理</text>
        <text class="menu-desc">维护已排敏安全食品，监控未排敏风险食材</text>
      </view>
      <view class="menu-arrow">➔</view>
    </view>

    <view class="menu-item" bindtap="navigateToPage" data-page="album">
      <view class="menu-icon">🖼️</view>
      <view class="menu-body">
        <text class="menu-title">宝宝相册</text>
        <text class="menu-desc">限制上传最多10张萌照，支持从中挑选设为宝宝头像</text>
      </view>
      <view class="menu-arrow">➔</view>
    </view>
  </view>

  <!-- 3. 设置面板 -->
  <view class="section-title">⚙️ 系统维护</view>
  <view class="card menu-card-list">
    <view class="menu-item" bindtap="syncLocalDataToCloud">
      <view class="menu-icon">☁️</view>
      <view class="menu-body">
        <text class="menu-title">同步/备份数据至云数据库</text>
        <text class="menu-desc">将本地大便、饮水、疫苗、大事记同步写入微信云端数据库集合中</text>
      </view>
      <view class="menu-arrow">➔</view>
    </view>

    <view class="menu-item" bindtap="clearAppData">
      <view class="menu-icon">🗑️</view>
      <view class="menu-body">
        <text class="menu-title" style="color: #e53e3e;">清空本地所有打卡缓存</text>
        <text class="menu-desc">删除本地记录并重置加载默认数据</text>
      </view>
      <view class="menu-arrow">➔</view>
    </view>
  </view>

  <!-- 4. 微信登录授权信息补充弹窗 -->
  <view class="modal-overlay" wx:if="{{ showLoginModal }}">
    <view class="modal-card">
      <view class="modal-header">
        <text class="modal-title">完善看护人信息</text>
        <text class="modal-close" bindtap="closeLoginModal">✕</text>
      </view>
      <view class="modal-body">
        <view class="form-item avatar-select-item">
          <text class="lbl">授权头像</text>
          <button class="avatar-wrapper" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
            <image class="avatar-preview" src="{{ tempAvatarUrl || '/assets/avatar_default.png' }}"></image>
          </button>
          <text class="hint" style="text-align: center;margin-top: 8rpx;">点击圆圈可直接获取微信头像</text>
        </view>
        <view class="form-item" style="margin-top:20rpx">
          <text class="lbl">授权昵称</text>
          <input type="nickname" placeholder="请选择或输入微信昵称" value="{{ inputNickname }}" bindinput="onNicknameInput" bindblur="onNicknameInput" />
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn btn-primary btn-block" bindtap="submitLoginProfile">确认登录</button>
      </view>
    </view>
  </view>

</view>
