<!--pages/my/index.wxml-->
<view class="container page-anim-{{ animKey }}">
  
  <!-- 1. 顶部小名片 -->
  <view class="my-profile-header">
    <block wx:if="{{ isLoggedIn }}">
      <view class="avatar-edit-wrap" bindtap="openEditModal">
        <image class="avatar-img" src="{{ userInfo.avatarUrl }}" mode="aspectFill"></image>
        <!-- <view class="avatar-edit-badge">✏️</view> -->
      </view>
      <view class="baby-info-box">
        <view class="profile-name-row">
          <text class="baby-name">{{ userInfo.nickName }} (看护人)</text>
          <text class="edit-profile-link" bindtap="openEditModal">编辑</text>
          <text class="logout-link" bindtap="handleLogout">退出</text>
        </view>
        <text class="baby-age" wx:if="{{ babyInfo }}">实际月龄：{{ actualAge }} | 纠正：{{ correctedAge }}</text>
        <text class="baby-age" wx:else style="color: #e53e3e;">⚠️ 请先在下方设置宝宝档案</text>
      </view>
    </block>
    <block wx:else>
      <view class="avatar-box">👤</view>
      <view class="baby-info-box" bindtap="handleLogin">
        <text class="baby-name text-link">点击微信授权登录 ➔</text>
        <text class="baby-age">授权以进行云数据库同步与多端看护</text>
      </view>
    </block>
  </view>

  <!-- 2. 二级功能菜单导航流 -->
  <view class="section-title">🛠️ 宝宝日常照护快捷记账</view>
  
  <view class="card menu-card-list">
    <view class="menu-item" bindtap="navigateToPage" data-page="baby">
      <view class="menu-icon">👶</view>
      <view class="menu-body">
        <text class="menu-title">宝宝档案设置</text>
        <text class="menu-desc">修改宝宝姓名、公历生日、早产纠正偏移天数</text>
      </view>
      <view class="menu-arrow">➔</view>
    </view>

    <view class="menu-item" bindtap="navigateToPage" data-page="bowel">
      <view class="menu-icon">💩</view>
      <view class="menu-body">
        <text class="menu-title">排便与肠胃记录</text>
        <text class="menu-desc">记录每天大便次数、颜色、有无出血</text>
      </view>
      <view class="menu-arrow">➔</view>
    </view>

    <view class="menu-item" bindtap="navigateToPage" data-page="sleep">
      <view class="menu-icon">😴</view>
      <view class="menu-body">
        <text class="menu-title">宝宝睡眠记录</text>
        <text class="menu-desc">记录每日睡眠时段、统计睡眠总时长</text>
      </view>
      <view class="menu-arrow">➔</view>
    </view>

    <view class="menu-item" bindtap="navigateToPage" data-page="nutrition">
      <view class="menu-icon">🍼</view>
      <view class="menu-body">
        <text class="menu-title">饮奶与饮水记录</text>
        <text class="menu-desc">管理每日奶量限制、补充水分打卡</text>
      </view>
      <view class="menu-arrow">➔</view>
    </view>

    <view class="menu-item" bindtap="navigateToPage" data-page="classes">
      <view class="menu-icon">🏫</view>
      <view class="menu-body">
        <text class="menu-title">宝宝上课打卡</text>
        <text class="menu-desc">管理课程出勤打卡、余额充值与扣费记录</text>
      </view>
      <view class="menu-arrow">➔</view>
    </view>

    <view class="menu-item" bindtap="navigateToPage" data-page="growth">
      <view class="menu-icon">📈</view>
      <view class="menu-body">
        <text class="menu-title">身高体重与发育</text>
        <text class="menu-desc">记录身高、体重、头围、脚长，生成成长发育曲线</text>
      </view>
      <view class="menu-arrow">➔</view>
    </view>

    <view class="menu-item" bindtap="navigateToPage" data-page="allergen">
      <view class="menu-icon">🥦</view>
      <view class="menu-body">
        <text class="menu-title">排敏食材管理</text>
        <text class="menu-desc">维护已排敏安全食品，监控未排敏风险食材</text>
      </view>
      <view class="menu-arrow">➔</view>
    </view>

    <view class="menu-item" bindtap="navigateToPage" data-page="album">
      <view class="menu-icon">🖼️</view>
      <view class="menu-body">
        <text class="menu-title">宝宝相册</text>
        <text class="menu-desc">限制上传最多10张萌照，支持从中挑选设为宝宝头像</text>
      </view>
      <view class="menu-arrow">➔</view>
    </view>

    <view class="menu-item" bindtap="navigateToPage" data-page="family">
      <view class="menu-icon">🏡</view>
      <view class="menu-body">
        <text class="menu-title">家庭协同共享</text>
        <text class="menu-desc">获取家庭同步码邀请爱人，多端数据自动刷新同步</text>
      </view>
      <view class="menu-arrow">➔</view>
    </view>
  </view>

  <!-- 自定义快捷入口 -->
  <view class="shortcut-header">
    <text class="section-title" style="margin-bottom:0">⚡ 自定义快捷入口</text>
    <view class="shortcut-add-btn" bindtap="openNewTimerModal">
      <text>＋ 新增模块</text>
    </view>
  </view>
  <text class="shortcut-sub-hint">按住卡片可删除自定义模块</text>
  <view class="shortcut-grid">
    <!-- 用户自创的计时模块 -->
    <view class="shortcut-card" wx:for="{{ customTimers }}" wx:key="id"
      bindtap="goTimer"
      bindlongpress="deleteCustomTimer" data-id="{{ item.id }}">
      <text class="shortcut-icon">{{ item.icon }}</text>
      <text class="shortcut-name">{{ item.name }}</text>
      <text class="shortcut-subdesc">{{ item.todayHours }}h / {{ item.targetHours }}h</text>
    </view>
    <!-- 无自定义模块时的提示 -->
    <view class="shortcut-empty" wx:if="{{ customTimers.length === 0 }}">
      <text>点击“新增模块”创建自定义计时快捷入口</text>
    </view>
  </view>


  <!-- 3. 底部版本号（连续点击10次解锁开发者模式） -->
  <view class="version-footer" bindtap="onVersionTap">
    <text class="version-text">珑珑成长助手 v1.0.0</text>
  </view>

  <!-- 4. 开发者数据导入面板（隐藏入口，点击版本号10次后展示） -->
  <view class="card dev-panel" wx:if="{{ showDevPanel }}">
    <view class="section-title">🔧 开发者数据导入</view>
    <text class="dev-hint">从手机中选取 JSON 种子文件，批量导入到微信云数据库。每个文件将根据文件名自动匹配对应的云数据库集合。</text>

    <!-- 集合名称与文件名映射说明 -->
    <view class="dev-mapping-list">
      <text class="dev-mapping-item">📜 timeline_events.json → timeline_events</text>
      <text class="dev-mapping-item">💉 vaccines.json → vaccines</text>
      <text class="dev-mapping-item">🏥 healthcares.json → healthcares</text>
      <text class="dev-mapping-item">📊 assessments.json → assessments</text>
      <text class="dev-mapping-item">🩺 clinical_logs.json → clinical_logs</text>
      <text class="dev-mapping-item">🥦 safe_foods.json → safe_foods</text>
      <text class="dev-mapping-item">🍊 risk_foods.json → risk_foods</text>
      <text class="dev-mapping-item">🍽️ meal_plans.json → meal_plans</text>
      <text class="dev-mapping-item">🏫 classes.json → classes</text>
      <text class="dev-mapping-item">📈 growth.json → growth</text>
    </view>

    <button class="btn btn-primary btn-block" style="margin-top: 20rpx;" bindtap="selectAndImportJsonFiles">
      📂 选取 JSON 文件并导入云数据库
    </button>

    <!-- 导入进度日志 -->
    <view class="dev-log" wx:if="{{ importLogs.length > 0 }}">
      <view class="dev-log-item" wx:for="{{ importLogs }}" wx:key="index">
        <text class="{{ item.success ? 'log-success' : 'log-error' }}">{{ item.text }}</text>
      </view>
    </view>

    <button class="btn btn-outline-secondary btn-block" style="margin-top: 16rpx;" bindtap="closeDevPanel">
      关闭开发者面板
    </button>
  </view>

</view>

<!-- 编辑看护人信息弹窗 -->
<view class="modal-overlay" wx:if="{{ showEditModal }}">
  <view class="modal-card">
    <view class="modal-header">
      <text class="modal-title">✏️ 编辑看护人信息</text>
      <text class="modal-close" bindtap="closeEditModal">✕</text>
    </view>
    <view class="modal-body">
      <view class="edit-avatar-section">
        <image class="edit-avatar-img" src="{{ editAvatarTemp || (userInfo && userInfo.avatarUrl) || '/assets/avatar_default.png' }}" mode="aspectFill"></image>
        <button class="edit-avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">更换头像</button>
      </view>
      <view class="form-item">
        <text class="lbl">看护人昵称 *</text>
        <input type="text" placeholder="输入昵称" value="{{ editNickname }}" bindinput="onEditNicknameInput" />
      </view>
    </view>
    <view class="modal-footer">
      <button class="btn btn-primary btn-block" bindtap="saveEditProfile">保存</button>
    </view>
  </view>
</view>

<!-- 新增计时模块弹窗 -->
<view class="modal-overlay" wx:if="{{ showNewTimerModal }}">
  <view class="modal-card">
    <view class="modal-header">
      <text class="modal-title">➕ 新增计时模块</text>
      <text class="modal-close" bindtap="closeNewTimerModal">✕</text>
    </view>
    <view class="modal-body">
      <!-- 模块类型选择 -->
      <view class="form-item">
        <text class="lbl">模块类型</text>
        <view class="type-selector-row">
          <view class="type-option {{ newTimerType === 'timer' ? 'type-option-active' : '' }}" bindtap="setNewTimerType" data-type="timer">
            <text class="type-option-icon">⏱️</text>
            <text class="type-option-name">计时器</text>
            <text class="type-option-desc">开始/停止自动计时</text>
          </view>
          <view class="type-option {{ newTimerType === 'range' ? 'type-option-active' : '' }}" bindtap="setNewTimerType" data-type="range">
            <text class="type-option-icon">📅</text>
            <text class="type-option-name">时间段</text>
            <text class="type-option-desc">填写开始~结束时间</text>
          </view>
        </view>
      </view>
      <!-- 图标选择 -->
      <view class="form-item">
        <text class="lbl">选择图标</text>
        <scroll-view class="icon-picker-row" scroll-x="true">
          <view class="icon-opt {{ newTimerIcon === icon ? 'icon-opt-sel' : '' }}"
            wx:for="{{ timerIconOptions }}" wx:key="*this" wx:for-item="icon"
            bindtap="selectTimerIcon" data-icon="{{ icon }}">{{ icon }}</view>
        </scroll-view>
      </view>
      <view class="form-item">
        <text class="lbl">模块标题 *</text>
        <input type="text" placeholder="如：眼罩遮盖、睡眠计时、训练时长"
          value="{{ newTimerName }}" bindinput="onNewTimerInput" data-field="newTimerName" />
      </view>
      <view class="form-item">
        <text class="lbl">功能说明</text>
        <input type="text" placeholder="如：矫正训练、日常作息"
          value="{{ newTimerDesc }}" bindinput="onNewTimerInput" data-field="newTimerDesc" />
      </view>
      <view class="form-item">
        <text class="lbl">每日目标（小时）</text>
        <input type="number" placeholder="如：4" value="{{ newTimerTargetHours }}"
          bindinput="onNewTimerInput" data-field="newTimerTargetHours" />
      </view>
    </view>
    <view class="modal-footer">
      <button class="btn btn-primary btn-block" bindtap="saveNewTimerModule">创建模块</button>
    </view>
  </view>
</view>
